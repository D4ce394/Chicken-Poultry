# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# PostgreSQL Database Configuration
DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/ai_frss
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ai_frss
DB_USER=your_username
DB_PASSWORD=your_password
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# YOLO Models Configuration
YOLO_MODELS_PATH=yolo_models
DEFAULT_CONFIDENCE=0.5
DEFAULT_IOU_THRESHOLD=0.45
MAX_DETECTIONS=100

# Image Processing
MAX_IMAGE_WIDTH=1280
MAX_IMAGE_HEIGHT=720
ALLOWED_IMAGE_FORMATS=jpg,jpeg,png,bmp,tiff

# Performance
PRELOAD_MODELS=intrusion,people
MODEL_CACHE_SIZE=4
INFERENCE_DEVICE=cpu  # or 'cuda' if GPU available

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# File Storage (for uploaded images)
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760  # 10MB in bytes
