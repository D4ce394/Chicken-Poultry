{
    "compilerOptions": {
        "target": "es6",
        "module": "commonjs",
        "outDir": "./dist",
        "rootDir": "./src",
        "baseUrl": "./src",
        "paths": {
            "@/*": ["*"],
            "@routes/*": ["routes/*"],
            "@database/*": ["database/*"],
            "@utils/*": ["utils/*"],
            "@types/*": ["types/*"],
            "@modules/*": ["modules/*"],
            "@config/*": ["config/*"],
            "@middlewares/*": ["middlewares/*"],
        "@interfaces/*": ["interfaces/*"],


        },
        "esModuleInterop": true,
        "typeRoots": ["node_modules/@types"],
        "types": ["node", "jest"],             // ✅ tambahkan ini
        "strict": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "lib": ["esnext", "dom"]
    },
    "include": ["src/**/*.ts"],  // ✅ pastikan tests juga di-include
    "exclude": ["node_modules"]
}
