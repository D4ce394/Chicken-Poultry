# Salin nilai-nilai ini ke Railway → Variables tab
NODE_ENV=production
PORT=3000

# SQLite — Railway akan simpan file ini di persistent volume /data
SQLITE_PATH=/data/sv-fs.sqlite

# JWT — salin dari .env lokal kamu
JWT_ACCESS_TOKEN_SECRET=a5d269d970eb746565c3b9d44cb9f4cec128b547b026e30628889e1905e1b71a729632839cacc9e6b8ce4d07f2d7546bb0cd83235901fbfd3c1a20345dfb7ec6

# URL Railway akan isi otomatis setelah deploy
BASE_URL=https://<your-app>.up.railway.app
