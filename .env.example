# ════════════════════════════════════════════════
#  AI-FRSS Dashboard — Environment Variables
#  Salin file ini ke .env lalu isi nilainya
# ════════════════════════════════════════════════

# ─── Frontend ────────────────────────────────────
PUBLIC_API_URL=http://localhost:3001/api
PUBLIC_BE2_URL=http://localhost:8000

# ─── Backend 1 (be - Express + Prisma) ──────────
JWT_ACCESS_TOKEN_SECRET=ganti_dengan_secret_yang_kuat
BASE_URL=http://localhost:3001
# SQLite (default, tidak perlu server DB):
DATABASE_URL=file:/app/data/mobile.db
# PostgreSQL (opsional):
# DATABASE_URL=postgresql://user:pass@host:5432/frss

# ─── Backend 2 (be2 - FastAPI + YOLO) ───────────
FIREBASE_DATABASE_URL=https://rfid-de0fd-default-rtdb.asia-southeast1.firebasedatabase.app
BE2_SECRET_KEY=ganti_dengan_secret_panjang
BE2_DATABASE_URL=
INFERENCE_DEVICE=cpu
LOG_LEVEL=INFO

# ─── Backend 3 (be3 - Express face recognition) ─
# DB_HOST diisi otomatis "mysql" oleh Docker — tidak perlu diubah
BE3_DB_USER=root
BE3_DB_PASSWORD=root
BE3_DB_NAME=recognition-kp
BE3_JWT_SECRET=ganti_dengan_secret_yang_kuat
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
